{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/join",
        "destination": "/index.html"
      },
      {
        "source": "/join/",
        "destination": "/index.html"
      }
    ]
  }
}
